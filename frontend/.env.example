# JOINUS Ecosystem - Frontend Configuration
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser

# WalletConnect Cloud Project ID (Required for RainbowKit)
# Get yours at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID="your_walletconnect_project_id"

# Smart Contract Deployments (Arbitrum)
NEXT_PUBLIC_JNS_TOKEN_ADDRESS="0x0000000000000000000000000000000000000001"
NEXT_PUBLIC_JNS_STAKING_ADDRESS="0x0000000000000000000000000000000000000002"
NEXT_PUBLIC_JNS_TIMELOCK_ADDRESS="0x0000000000000000000000000000000000000003"
NEXT_PUBLIC_JNS_GOVERNOR_ADDRESS="0x0000000000000000000000000000000000000004"

# Pimlico (Account Abstraction & Gasless Transactions)
NEXT_PUBLIC_PIMLICO_API_KEY="your_pimlico_api_key"
